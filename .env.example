# ── API Endpoint ─────────────────────────────────────────────────────────────
# Leave blank or set to /api/claude for Vercel (uses api/claude.js)
# Set to /api/claude.php for Hostinger
# VITE_API_ENDPOINT=/api/claude.php

# ── Supabase (Free account auth) ─────────────────────────────────────────────
# 1. Go to https://supabase.com and create a free project
# 2. In your project: Settings → API
# 3. Copy "Project URL" and "anon/public" key below
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

TAVILY_API_KEY=your_tavily_key_here

# ── NOTE ──────────────────────────────────────────────────────────────────────
# The Anthropic API key goes directly in api/claude.php (server-side only).
# Do NOT put it here — this file is embedded into the frontend bundle at build time.
